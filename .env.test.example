# Variáveis E2E — copie para .env.test e preencha com os valores de `npx supabase status`
# NUNCA use credenciais de produção aqui. E2E roda somente contra o Supabase local.

# Variáveis VITE_ — bakeadas no bundle por `vite build --mode test`
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<valor-de-supabase-status>
VITE_ADOPTION_FORM_URL=https://forms.gle/fake-e2e-test

# Variáveis E2E_ — usadas somente pelos scripts Node de setup do Playwright
E2E_SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY-de-supabase-status>
E2E_ADMIN_EMAIL=admin-e2e@abrigo.test
E2E_ADMIN_PASSWORD=AbrigoE2ETest123!
