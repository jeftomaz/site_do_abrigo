{
  "name": "site-do-abrigo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "gen:types": "supabase gen types typescript --local > src/shared/types/db.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:rls": "npx supabase test db supabase/tests",
    "test:e2e": "vite build --mode test && npx playwright test",
    "e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  }
}
